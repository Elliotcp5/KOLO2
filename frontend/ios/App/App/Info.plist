<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
	<string>KOLO</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>
	<key>UIStatusBarStyle</key>
	<string>UIStatusBarStyleLightContent</string>
	<key>NSContactsUsageDescription</key>
	<string>KOLO a besoin d'accéder à vos contacts pour vous permettre d'importer rapidement vos prospects immobiliers.</string>
	<key>NSCameraUsageDescription</key>
	<string>KOLO utilise l'appareil photo pour ajouter des photos à vos biens et prospects.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>KOLO accède à votre bibliothèque photos pour ajouter des images à vos biens immobiliers.</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>io.kolo.app</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>io.kolo.app</string>
				<string>kolo</string>
			</array>
		</dict>
	</array>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>NSMicrophoneUsageDescription</key>
	<string>KOLO utilise le microphone pour enregistrer tes notes vocales de terrain (notes de visite, comptes-rendus de rendez-vous).</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>KOLO accède à ta photothèque pour ajouter des photos aux dossiers de tes biens immobiliers.</string>
	<key>NSCameraUsageDescription</key>
	<string>KOLO utilise la caméra pour prendre en photo les documents et les biens lors de tes visites.</string>
	<key>NSContactsUsageDescription</key>
	<string>KOLO importe tes contacts pour t'aider à les retrouver et à gérer ton portefeuille clients.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>KOLO utilise ta position pour t'afficher les annonces et DPE de ton secteur lors des visites.</string>
        <key>NSAppTransportSecurity</key>
        <dict>
                <key>NSAllowsArbitraryLoads</key>
                <false/>
                <key>NSExceptionDomains</key>
                <dict>
                        <key>emergentagent.com</key>
                        <dict>
                                <key>NSIncludesSubdomains</key>
                                <true/>
                                <key>NSExceptionAllowsInsecureHTTPLoads</key>
                                <false/>
                                <key>NSExceptionRequiresForwardSecrecy</key>
                                <true/>
                                <key>NSExceptionMinimumTLSVersion</key>
                                <string>TLSv1.2</string>
                        </dict>
                        <key>trykolo.io</key>
                        <dict>
                                <key>NSIncludesSubdomains</key>
                                <true/>
                                <key>NSExceptionMinimumTLSVersion</key>
                                <string>TLSv1.2</string>
                        </dict>
                </dict>
        </dict>
        <key>NSMicrophoneUsageDescription</key>
        <string>KOLO utilise le micro pour enregistrer tes notes vocales et les transcrire automatiquement.</string>
        <key>NSSpeechRecognitionUsageDescription</key>
        <string>KOLO utilise la reconnaissance vocale pour transcrire tes dictées en texte.</string>
        <key>NSPhotoLibraryUsageDescription</key>
        <string>KOLO accède à ta photothèque pour joindre des images à tes dossiers.</string>
        <key>NSFaceIDUsageDescription</key>
        <string>KOLO utilise Face ID pour sécuriser l'accès à ton compte.</string>
</dict>
</plist>
